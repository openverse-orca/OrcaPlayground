<mujoco model="Skydio X2">
  <compiler autolimits="true" assetdir="assets" texturedir="textures/" meshdir="Meshes/" balanceinertia="true"/>
  <option timestep="0.01" density="1.225" viscosity="1.8e-5"/>
  <default>
    <default class="x2">
      <geom mass="0"/>
      <motor ctrlrange="0 13"/>
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="box"/>
      </default>
      <default class="rotor_visual">
        <geom type="ellipsoid" size=".13 .13 .01" group="2" contype="0" conaffinity="0"/>
      </default>
      <site group="5"/>
    </default>
    <joint damping="0.1" armature="0.01" frictionloss="0.02"/>
    <default class="rotor_joint">
      <joint type="hinge" axis="0 0 1" limited="false" damping="0.02" armature="0.0005"/>
    </default>
  </default>
  <asset>
    <texture type="2d" file="X2_lowpoly_texture_SpinningProps_1024.png"/>
    <material name="phong3SG" texture="X2_lowpoly_texture_SpinningProps_1024"/>
    <material name="invisible" rgba="0 0 0 0"/>
    <mesh class="x2" file="X2_lowpoly.obj" scale="0.01 0.01 0.01"/>
  </asset>
  <worldbody>
    <light name="spotlight" mode="targetbodycom" target="drone_frame" pos="0 -1 2"/>
    <body name="drone_frame" pos="0 0 0.1" childclass="x2">
      <joint name="drone_free" type="free"/>
      <camera name="track" pos="-1 0 .5" xyaxes="0 -1 0 1 0 2" mode="trackcom"/>
      <!-- 把 free joint 对到近似质心，主体质量集中在刚体惯量上，旋翼仅保留可视旋转。 -->
      <body name="Drone">
        <inertial pos="0 0 0" mass="1.325" diaginertia="0.022 0.014 0.034"/>
        <site name="imu" pos="0 0 0"/>
        <site name="drone_body_center_site" pos="0 0 0"/>
        <geom material="phong3SG" mesh="X2_lowpoly" class="visual" quat="0 0 1 1" pos="0 0 -0.054" name="default_geom0"/>
        <geom class="collision" size=".06 .027 .02" pos=".04 0 -.034" name="default_geom1"/>
        <geom class="collision" size=".06 .027 .02" pos=".04 0 .006" name="default_geom2"/>
        <geom class="collision" size=".05 .027 .02" pos="-.07 0 .011" name="default_geom3"/>
        <geom class="collision" size=".023 .017 .01" pos="-.137 .008 .011" quat="1 0 0 1" name="default_geom4"/>
        <geom size=".16 .04 .02" pos="0 0 -.034" type="ellipsoid" class="visual" material="invisible" name="default_geom9"/>

        <site name="thrust1" pos="-.14 -.18 -.004"/>
        <site name="thrust2" pos="-.14 .18 -.004"/>
        <site name="thrust3" pos=".14 .18 .026"/>
        <site name="thrust4" pos=".14 -.18 .026"/>

        <body name="rotor_fr" pos="-.14 -.18 -.004">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
          <joint class="rotor_joint" name="FR_joint"/>
          <site name="rotor_fr_site" pos="0 0 0"/>
          <geom name="rotor1" class="rotor_visual"/>
        </body>

        <body name="rotor_fl" pos="-.14 .18 -.004">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
          <joint class="rotor_joint" name="FL_joint"/>
          <site name="rotor_fl_site" pos="0 0 0"/>
          <geom name="rotor2" class="rotor_visual"/>
        </body>

        <body name="rotor_bl" pos=".14 .18 .026">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
          <joint class="rotor_joint" name="BL_joint"/>
          <site name="rotor_bl_site" pos="0 0 0"/>
          <geom name="rotor3" class="rotor_visual"/>
        </body>

        <body name="rotor_br" pos=".14 -.18 .026">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
          <joint class="rotor_joint" name="BR_joint"/>
          <site name="rotor_br_site" pos="0 0 0"/>
          <geom name="rotor4" class="rotor_visual"/>
        </body>
      </body>
    </body>
  </worldbody>
  <sensor>
    <gyro name="body_gyro" site="imu"/>
    <accelerometer name="body_linacc" site="imu"/>
    <framequat name="body_quat" objtype="site" objname="imu"/>
  </sensor>
</mujoco>